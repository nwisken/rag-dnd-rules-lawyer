# Copy to .env and fill in. Never commit .env.

# Postgres (matches docker-compose defaults; change both together)
POSTGRES_USER=ruleslawyer
POSTGRES_PASSWORD=ruleslawyer
POSTGRES_DB=ruleslawyer
DATABASE_URL=postgresql://ruleslawyer:ruleslawyer@localhost:5432/ruleslawyer

# Embedding model — an experiment parameter, tracked in MLflow (Phase 2), not a constant
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# LLM provider (Phase 1, generation step) — set when we wire up llm.py
# ANTHROPIC_API_KEY=
